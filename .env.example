# Create a bot with @BotFather and paste the token only into your local .env.
BOT_TOKEN=

# Comma-separated Telegram numeric user IDs allowed to administer the shop.
ADMIN_IDS=

SUPPORT_USERNAME=AWP_ON
DEFAULT_LOCALE=en
DATABASE_PATH=data/shop.db
BANNER_PATH=assets/welcome.gif.mp4
ORDER_RESERVATION_MINUTES=10

# Keep false until prices, stock, delivery and terms have been checked.
PAYMENTS_ENABLED=false
# Numeric Binance Pay ID that buyers will transfer USDT to.
BINANCE_ID=

# Optional mandatory public channel subscription, without @.
# Add the bot to this channel as an administrator so it can verify members.
REQUIRED_CHANNEL_USERNAME=mydrecsales

# Optional Fernet key for encrypted /backup files. On Render the bot reuses
# DATABASE_BOOTSTRAP_KEY when this value is empty.
BACKUP_ENCRYPTION_KEY=

# Optional premium/custom emoji ID overrides for main menu buttons.
# Empty values use the curated MydrecShop theme. Product icons are configured at runtime.
EMOJI_CATALOG_ID=
EMOJI_ORDERS_ID=
EMOJI_PROFILE_ID=
EMOJI_LANGUAGE_ID=
EMOJI_SETTINGS_ID=
EMOJI_BUY_ID=
EMOJI_BACK_ID=
